import torch
from transformers import GPT2LMHeadModel, GPT2Tokenizer
import gym
from gym import spaces
import numpy as np

# 1. LLM模型加载
class ReactionPredictor:
    def __init__(self, model_name='gpt2'):
        # 使用GPT2作为基础LLM模型，可以根据需求切换为其他模型
        self.model = GPT2LMHeadModel.from_pretrained(model_name)
        self.tokenizer = GPT2Tokenizer.from_pretrained(model_name)
    
    def predict_reaction(self, input_text):
        # 对反应输入进行tokenization
        inputs = self.tokenizer.encode(input_text, return_tensors='pt')
        
        # 使用模型生成反应步骤
        outputs = self.model.generate(inputs, max_length=100, num_return_sequences=1)
        
        # 解码生成的反应步骤
        reaction_steps = self.tokenizer.decode(outputs[0], skip_special_tokens=True)
        return reaction_steps

# 2. 强化学习环境：模拟反应条件优化
class ReactionEnv(gym.Env):
    def __init__(self):
        super(ReactionEnv, self).__init__()
        # 定义动作空间：例如，选择反应温度、压力等
        self.action_space = spaces.Discrete(10)  # 例如：10个不同的温度选择
        # 定义观察空间：例如，反应物的浓度和初始条件
        self.observation_space = spaces.Box(low=0, high=1, shape=(3,), dtype=np.float32)
    
    def reset(self):
        # 重置环境的状态
        self.state = np.random.random(3)  # 随机初始化状态
        return self.state
    
    def step(self, action):
        # 通过动作更新反应条件
        reaction_condition = action * 0.1  # 假设动作对应某种调整
        reward = self.calculate_reward(reaction_condition)
        
        # 更新环境状态（反应条件）
        self.state = np.random.random(3)  # 假设新的状态变化
        done = False  # 假设环境不会在一次步骤中结束
        
        return self.state, reward, done, {}
    
    def calculate_reward(self, condition):
        # 简化的奖励函数：优化条件时，假设奖励与条件的好坏相关
        return np.exp(-condition**2)  # 越接近0，奖励越高

# 3. 强化学习Agent
class RLAgent:
    def __init__(self, env):
        self.env = env
        self.model = torch.nn.Sequential(
            torch.nn.Linear(env.observation_space.shape[0], 128),
            torch.nn.ReLU(),
            torch.nn.Linear(128, env.action_space.n)
        )
        self.optimizer = torch.optim.Adam(self.model.parameters(), lr=0.001)
    
    def choose_action(self, state):
        state_tensor = torch.tensor(state, dtype=torch.float32)
        q_values = self.model(state_tensor)
        action = torch.argmax(q_values).item()  # 贪婪选择动作
        return action
    
    def train(self, num_episodes=100):
        for episode in range(num_episodes):
            state = self.env.reset()
            done = False
            while not done:
                action = self.choose_action(state)
                next_state, reward, done, _ = self.env.step(action)
                
                # 简化的Q-learning 更新
                q_value = self.model(torch.tensor(state, dtype=torch.float32))
                target = reward + 0.9 * torch.max(self.model(torch.tensor(next_state, dtype=torch.float32)))
                loss = torch.nn.MSELoss()(q_value[action], target)
                
                self.optimizer.zero_grad()
                loss.backward()
                self.optimizer.step()
                
                state = next_state

# 4. 主程序：结合LLM和RL Agent来预测并优化反应过程
def main():
    # 初始化LLM模型
    reaction_predictor = ReactionPredictor()
    
    # 示例反应输入
    reaction_input = "Reactant A and B in the presence of catalyst C under heat"
    predicted_steps = reaction_predictor.predict_reaction(reaction_input)
    print(f"Predicted Reaction Steps: {predicted_steps}")
    
    # 初始化强化学习环境和Agent
    env = ReactionEnv()
    agent = RLAgent(env)
    
    # 训练Agent以优化反应条件
    agent.train(num_episodes=100)
    print("Training complete.")

if __name__ == "__main__":
    main()
